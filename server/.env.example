# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/legacy-wealth
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/legacy-wealth

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d

# Razorpay (get from https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

# CORS
CLIENT_URL=http://localhost:5173

# Default admin (used by seed script)
ADMIN_EMAIL=admin@legacywealth.in
ADMIN_PASSWORD=ChangeThisAdminPass2026!
ADMIN_NAME=Sanjeev Sharma
